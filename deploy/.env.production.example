# Copy to /opt/sauti/.env.production on the server. Never commit the real file.
SAUTI_DOMAIN=sauti.uk
GHCR_OWNER=zacle
JAVA_OPTS=-Xms256m -Xmx1536m
SPRING_PROFILES_ACTIVE=production

# Production uses managed services. Prefer filling NEON_* / UPSTASH_* in
# .env.external-source, then run deploy/configure-external-services-env.sh on the server.
NEON_DATABASE_URL=postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require
NEON_POOLED_DATABASE_URL=postgresql://USER:PASSWORD@POOLER_HOST/DATABASE?sslmode=require
DB_URL=jdbc:postgresql://POOLER_HOST/DATABASE?sslmode=require
DB_USER=USER
DB_PASSWORD=PASSWORD
SPRING_FLYWAY_URL=jdbc:postgresql://DIRECT_HOST/DATABASE?sslmode=require
SPRING_FLYWAY_USER=USER
SPRING_FLYWAY_PASSWORD=PASSWORD
SPRING_REDIS_HOST=example.upstash.io
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=replace-with-upstash-password
SPRING_REDIS_SSL_ENABLED=true

JWT_SECRET=replace-with-at-least-32-random-bytes
SAUTI_WEB_VOICE_TOKEN_SECRET=replace-with-at-least-32-random-bytes
SAUTI_TOOLS_ENCRYPTION_KEY=replace-with-exactly-32-byte-key
SAUTI_WEBHOOK_SIGNING_SECRET=replace-with-a-random-secret
AUTH_EXPOSE_DEV_TOKENS=false

PROVIDER_MODE=live
SAUTI_TELEPHONY_PROVIDER=telnyx
SAUTI_LLM_PROVIDER=spring-ai
SAUTI_LLM_PRIMARY_MODEL=gpt-5.4-mini
SAUTI_LLM_FALLBACK_MODEL=gemini-3.1-flash-lite
SAUTI_STT_STREAMING_PROVIDER=deepgram
SAUTI_TTS_STREAMING_PROVIDER=cartesia

GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIPTION_URL=https://api.openai.com/v1/audio/transcriptions
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_REALTIME_TRANSCRIPTION_DELAY=low
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime
OPENAI_REALTIME_CALLS_URL=https://api.openai.com/v1/realtime/calls
OPENAI_REALTIME_WEBSOCKET_URL=wss://api.openai.com/v1/realtime
OPENAI_REALTIME_TELEPHONY_ENABLED=true
OPENAI_REALTIME_CONVERSATION_MODEL=gpt-realtime-1.5
OPENAI_REALTIME_MAX_OUTPUT_TOKENS=512
OPENAI_REALTIME_CONTEXT_TOKEN_LIMIT=1000
OPENAI_REALTIME_CONTEXT_RETENTION_RATIO=0.8
OPENAI_TTS_PREVIEW_MODEL=gpt-4o-mini-tts
SAUTI_TEST_VOICE_RUNTIME=vapi
MANAGED_VOICE_PUBLIC_BASE_URL=https://sauti.uk
RETELL_API_KEY=
RETELL_API_BASE_URL=https://api.retellai.com
RETELL_DEFAULT_VOICE_ID=retell-Cimo
RETELL_MODEL=gpt-4.1-mini
ELEVENLABS_API_KEY=
ELEVENLABS_ENVIRONMENT=production
ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_API_BASE_URL=https://api.vapi.ai
VAPI_PUBLIC_BASE_URL=https://sauti.uk
VAPI_MODEL_PROVIDER=openai
VAPI_MODEL=gpt-4.1-mini
VAPI_TRANSCRIBER_PROVIDER=deepgram
VAPI_TRANSCRIBER_MODEL=agent
VAPI_TRANSCRIBER_LANGUAGE=agent
VAPI_FLUX_EOT_THRESHOLD=0.7
VAPI_FLUX_EOT_TIMEOUT_MS=2500
VAPI_VOICE_PROVIDER=vapi
VAPI_VOICE_ID=Savannah
VAPI_VOICE_VERSION=2
VAPI_VOICE_LANGUAGE=auto
VAPI_CARTESIA_MODEL=sonic-3
VAPI_TOOL_TIMEOUT_SECONDS=30
VAPI_DELAYED_MESSAGE_MS=1000
DEEPGRAM_API_KEY=
SAUTI_STT_STREAMING_PROVIDER=deepgram
DEEPGRAM_UTTERANCE_END_MS=1000
CARTESIA_API_KEY=
CARTESIA_DEFAULT_VOICE_ID=
CARTESIA_VERSION=2026-03-01
CARTESIA_MODEL_ID=sonic-3.5
CARTESIA_VOICES_URL=https://api.cartesia.ai/voices?limit=100
CARTESIA_WEBSOCKET_URL=wss://api.cartesia.ai/tts/websocket
CARTESIA_BYTES_URL=https://api.cartesia.ai/tts/bytes
CARTESIA_ACCESS_TOKEN_URL=https://api.cartesia.ai/access-token
CARTESIA_MAX_BUFFER_DELAY_MS=0
CARTESIA_OUTPUT_CONTAINER=raw
CARTESIA_OUTPUT_ENCODING=pcm_s16le
CARTESIA_OUTPUT_SAMPLE_RATE=16000
CARTESIA_PREVIEW_CONTAINER=mp3
CARTESIA_PREVIEW_ENCODING=pcm_s16le
CARTESIA_PREVIEW_SAMPLE_RATE=44100

TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_CONNECTION_ID=
TELNYX_AI_ENVIRONMENT=production
TELNYX_AI_REGION=
TELNYX_REQUIREMENT_GROUP_ID=
TELNYX_VALIDATE_SIGNATURE=true

WHATSAPP_VERIFY_TOKEN=
# Canonical Meta App Secret used by both webhook validation and Embedded Signup.
WHATSAPP_APP_SECRET=
WHATSAPP_VALIDATE_SIGNATURE=true
WHATSAPP_EMBEDDED_SIGNUP_APP_ID=
# Optional legacy alias; leave blank when WHATSAPP_APP_SECRET is set.
WHATSAPP_EMBEDDED_SIGNUP_APP_SECRET=
WHATSAPP_EMBEDDED_SIGNUP_CONFIGURATION_ID=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://sauti.uk/api/v1/auth/oauth/google/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://sauti.uk/api/v1/integrations/google-calendar/callback
GOOGLE_SHEETS_OAUTH_CLIENT_ID=
GOOGLE_SHEETS_OAUTH_CLIENT_SECRET=
GOOGLE_SHEETS_REDIRECT_URI=https://sauti.uk/api/v1/integrations/google_sheets/callback
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=https://sauti.uk/api/v1/integrations/hubspot/callback
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=https://sauti.uk/api/v1/integrations/salesforce/callback
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_REDIRECT_URI=https://sauti.uk/api/v1/integrations/calendly/callback
CALENDLY_AUTHORIZE_URL=https://auth.calendly.com/oauth/authorize
CALENDLY_TOKEN_URL=https://auth.calendly.com/oauth/token
CALENDLY_SCOPE=

SPRING_MAIL_HOST=smtp.resend.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=resend
SPRING_MAIL_PASSWORD=replace-with-resend-api-key
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
EMAIL_FROM=noreply@sauti.uk
EMAIL_FROM_NAME=Sauti
EMAIL_REPLY_TO=support@sauti.uk

SAUTI_DOCUMENT_STORAGE_PROVIDER=database
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
