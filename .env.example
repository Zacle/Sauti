# Copy this file to .env. Keep real credentials out of Git.

POSTGRES_DB=sauti
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8082
MANAGEMENT_PORT=8081
DASHBOARD_PORT=8088
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

DB_URL=jdbc:postgresql://localhost:5432/sauti
DB_USER=sauti
DB_PASSWORD=sauti

SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=
SPRING_REDIS_SSL_ENABLED=false
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025

JWT_SECRET=replace-with-a-long-random-secret
AUTH_EXPOSE_DEV_TOKENS=true
SAUTI_TOOLS_ENCRYPTION_KEY=replace-with-exactly-32-byte-key
SAUTI_WEBHOOK_SIGNING_SECRET=replace-with-a-random-secret

DASHBOARD_BASE_URL=https://sauti.uk
SAUTI_CORS_ALLOWED_ORIGINS=https://sauti.uk

PROVIDER_MODE=fake
SAUTI_TELEPHONY_PROVIDER=fake
SAUTI_STT_STREAMING_PROVIDER=noop
SAUTI_TTS_STREAMING_PROVIDER=elevenlabs
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEAKING_RATE=-2%
AZURE_SPEECH_PITCH=+0%
SAUTI_RECORDINGS_DIR=/data/recordings
SAUTI_CURATED_VOICE_IDS=
SAUTI_LLM_PROVIDER=spring-ai
SAUTI_LLM_DEFAULT_MODEL=gemini-3.1-flash-lite
SAUTI_LLM_ADVANCED_MODEL=gpt-5.4-mini
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
SAUTI_RAG_EMBEDDING_MODEL=gemini-embedding-2
SAUTI_RAG_TOP_K=4
SAUTI_RAG_MIN_SIMILARITY=0.30
SAUTI_RAG_MAX_DOCUMENT_CHARACTERS=100000
SAUTI_KNOWLEDGE_MAX_FILE_SIZE=10MB
SAUTI_WEB_VOICE_TOKEN_SECRET=replace-with-a-long-random-secret
SAUTI_WEB_VOICE_TOKEN_MINUTES=10
SAUTI_WEB_VOICE_WEBSOCKET_URL=wss://sauti.uk
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VALIDATE_SIGNATURE=true
WHATSAPP_GRAPH_API_BASE_URL=https://graph.facebook.com/v23.0
WHATSAPP_EMBEDDED_SIGNUP_APP_ID=
WHATSAPP_EMBEDDED_SIGNUP_APP_SECRET=
WHATSAPP_EMBEDDED_SIGNUP_CONFIGURATION_ID=
SAUTI_DOCUMENT_STORAGE_PROVIDER=firebase
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_CREDENTIALS_FILE=./secrets/firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json
SAUTI_CALENDAR_PROVIDER=local

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_OUTBOUND_ENABLED=false
TWILIO_OUTBOUND_FROM_NUMBER=
PUBLIC_BASE_URL=https://sauti.uk

# Required when SAUTI_TELEPHONY_PROVIDER=telnyx.
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_CONNECTION_ID=
TELNYX_API_BASE_URL=https://api.telnyx.com/v2
TELNYX_MEDIA_WEBSOCKET_BASE_URL=wss://sauti.uk/ws/telnyx/media
TELNYX_REQUIREMENT_GROUP_ID=
TELNYX_VALIDATE_SIGNATURE=true
TELNYX_WEBHOOK_TOLERANCE_SECONDS=300

DEEPGRAM_API_KEY=
DEEPGRAM_PRERECORDED_URL=https://api.deepgram.com/v1/listen
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LISTEN_URL=wss://api.deepgram.com/v1/listen

ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_STABILITY=0.38
ELEVENLABS_SIMILARITY_BOOST=0.78
ELEVENLABS_STYLE=0.12
ELEVENLABS_SPEED=0.98
ELEVENLABS_SPEAKER_BOOST=true
ELEVENLABS_STREAM_URL=wss://api.elevenlabs.io/v1/text-to-speech
ELEVENLABS_VOICES_URL=https://api.elevenlabs.io/v2/voices?page_size=100
ELEVENLABS_PREVIEW_URL=https://api.elevenlabs.io/v1/text-to-speech

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://sauti.uk/api/v1/auth/oauth/google/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://sauti.uk/api/v1/integrations/google-calendar/callback
GOOGLE_SHEETS_OAUTH_CLIENT_ID=
GOOGLE_SHEETS_OAUTH_CLIENT_SECRET=
GOOGLE_SHEETS_REDIRECT_URI=https://sauti.uk/api/v1/integrations/google_sheets/callback
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=https://sauti.uk/api/v1/integrations/hubspot/callback
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=https://sauti.uk/api/v1/integrations/salesforce/callback
SAUTI_INTEGRATIONS_WORKER_DELAY_MS=5000
SAUTI_INTEGRATIONS_DELIVERY_DELAY_MS=5000

SAUTI_LLM_WEBHOOK_URL=https://sauti.uk/agent-turn
SAUTI_LLM_DRAFT_WEBHOOK_URL=https://sauti.uk/agent-draft
SAUTI_LLM_WEBHOOK_SECRET=
SAUTI_CALENDAR_WEBHOOK_URL=https://sauti.uk/calendar-events
SAUTI_CALENDAR_WEBHOOK_SECRET=
